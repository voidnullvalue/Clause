#!/usr/bin/env bash
# Clause core: guarded launch, threshold stop, verified reset, exact resume.

set -uo pipefail

STATE_DIR="${CLAUSE_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/clause}"
LOG_FILE="$STATE_DIR/clause.log"
RUN_DIR="${CLAUSE_RUN_DIR:-}"
RUN_ID="${CLAUSE_RUN_ID:-}"
AUTH_FILE="${CLAUSE_AUTH_FILE:-}"
AUTH_TOKEN="${CLAUSE_AUTH_TOKEN:-}"
SUPERVISOR_PID="${CLAUSE_SUPERVISOR_PID:-0}"
FIVE_HOUR_STOP="${CLAUSE_5H_STOP:-90}"
SEVEN_DAY_STOP="${CLAUSE_7D_STOP:-90}"
AUTO_RESUME="${CLAUSE_AUTO_RESUME:-1}"
OPTIMIZATION_PROFILE="${CLAUSE_OPTIMIZATION_PROFILE:-1}"
RESUME_PROMPT="${CLAUSE_RESUME_PROMPT:-Usage limits are safely below the configured thresholds. Continue the original task from the exact current repository and session state. Before changing anything, inspect git status, git diff, any task list, and interrupted command results. Do not repeat completed external side effects.}"

POLL_SECONDS=1
HOOK_GRACE_SECONDS=15
TELEMETRY_GRACE_SECONDS=60
TELEMETRY_STALE_SECONDS=30
PROBE_TIMEOUT_SECONDS=90
PROBE_RETRY_INITIAL_SECONDS=30
PROBE_RETRY_MAX_SECONDS=300
TERM_GRACE_SECONDS=3

SAFETY_SETTINGS_JSON='{"statusLine":{"type":"command","command":"~/.local/libexec/clause/clause-statusline.sh","padding":0,"refreshInterval":1},"env":{"CLAUDE_CODE_DISABLE_BACKGROUND_TASKS":"1","CLAUDE_CODE_FORK_SUBAGENT":"0","CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS":"0","CLAUDE_CODE_SUBAGENT_MODEL":"haiku","CLAUDE_CODE_USE_POWERSHELL_TOOL":"0"},"permissions":{"deny":["Agent(general-purpose)","Agent(Plan)","Agent(model:opus)","Agent(isolation:*)","Workflow","Monitor","CronCreate","RemoteTrigger","ScheduleWakeup","SendMessage","PowerShell","Bash(run_in_background:true)"]},"hooks":{"SessionStart":[{"hooks":[{"type":"command","command":"~/.local/libexec/clause/clause-tool-gate.sh --session-start","timeout":5}]}],"PreToolUse":[{"matcher":"Agent|Bash|PowerShell|Workflow|Monitor|CronCreate|RemoteTrigger|ScheduleWakeup|SendMessage","hooks":[{"type":"command","command":"~/.local/libexec/clause/clause-tool-gate.sh --pre-tool-use","timeout":5}]}]}}'
RUNTIME_SETTINGS_JSON='{"model":"sonnet","effortLevel":"medium","autoCompactEnabled":true,"workflowSizeGuideline":"small","verbose":false,"statusLine":{"type":"command","command":"~/.local/libexec/clause/clause-statusline.sh","padding":0,"refreshInterval":1},"env":{"CLAUDE_CODE_DISABLE_BACKGROUND_TASKS":"1","CLAUDE_CODE_FORK_SUBAGENT":"0","CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS":"0","CLAUDE_CODE_SUBAGENT_MODEL":"haiku","CLAUDE_CODE_USE_POWERSHELL_TOOL":"0"},"permissions":{"deny":["Agent(general-purpose)","Agent(Plan)","Agent(model:opus)","Agent(isolation:*)","Workflow","Monitor","CronCreate","RemoteTrigger","ScheduleWakeup","SendMessage","PowerShell","Bash(run_in_background:true)"]},"hooks":{"SessionStart":[{"hooks":[{"type":"command","command":"~/.local/libexec/clause/clause-tool-gate.sh --session-start","timeout":5}]}],"PreToolUse":[{"matcher":"Agent|Bash|PowerShell|Workflow|Monitor|CronCreate|RemoteTrigger|ScheduleWakeup|SendMessage","hooks":[{"type":"command","command":"~/.local/libexec/clause/clause-tool-gate.sh --pre-tool-use","timeout":5}]}]}}'
RESUME_SETTINGS_JSON='{"autoCompactEnabled":true,"workflowSizeGuideline":"small","verbose":false,"statusLine":{"type":"command","command":"~/.local/libexec/clause/clause-statusline.sh","padding":0,"refreshInterval":1},"env":{"CLAUDE_CODE_DISABLE_BACKGROUND_TASKS":"1","CLAUDE_CODE_FORK_SUBAGENT":"0","CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS":"0","CLAUDE_CODE_SUBAGENT_MODEL":"haiku","CLAUDE_CODE_USE_POWERSHELL_TOOL":"0"},"permissions":{"deny":["Agent(general-purpose)","Agent(Plan)","Agent(model:opus)","Agent(isolation:*)","Workflow","Monitor","CronCreate","RemoteTrigger","ScheduleWakeup","SendMessage","PowerShell","Bash(run_in_background:true)"]},"hooks":{"SessionStart":[{"hooks":[{"type":"command","command":"~/.local/libexec/clause/clause-tool-gate.sh --session-start","timeout":5}]}],"PreToolUse":[{"matcher":"Agent|Bash|PowerShell|Workflow|Monitor|CronCreate|RemoteTrigger|ScheduleWakeup|SendMessage","hooks":[{"type":"command","command":"~/.local/libexec/clause/clause-tool-gate.sh --pre-tool-use","timeout":5}]}]}}'
PROBE_SETTINGS_JSON='{"model":"haiku","effortLevel":"low","verbose":false,"statusLine":{"type":"command","command":"~/.local/libexec/clause/clause-statusline.sh","padding":0,"refreshInterval":1},"env":{"CLAUDE_CODE_DISABLE_BACKGROUND_TASKS":"1","CLAUDE_CODE_FORK_SUBAGENT":"0","CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS":"0","CLAUDE_CODE_SUBAGENT_MODEL":"haiku","CLAUDE_CODE_USE_POWERSHELL_TOOL":"0"},"permissions":{"deny":["Agent","Workflow","Monitor","CronCreate","RemoteTrigger","ScheduleWakeup","SendMessage","PowerShell","Bash(run_in_background:true)"]},"hooks":{"SessionStart":[{"hooks":[{"type":"command","command":"~/.local/libexec/clause/clause-tool-gate.sh --session-start","timeout":5}]}],"PreToolUse":[{"matcher":"Agent|Bash|PowerShell|Workflow|Monitor|CronCreate|RemoteTrigger|ScheduleWakeup|SendMessage","hooks":[{"type":"command","command":"~/.local/libexec/clause/clause-tool-gate.sh --pre-tool-use","timeout":5}]}]}}'
EXPLORE_AGENT_JSON='{"Explore":{"description":"Targeted read-only repository lookup used only when exact files, symbols, or call paths are unknown.","prompt":"Search narrowly and return concise evidence. Prefer exact symbols, strings, and known directory boundaries. Do not broadly survey the repository. Do not inspect generated, dependency, cache, build, or vendor directories unless directly implicated. Do not paste entire files or large command outputs. Return only relevant file paths and line ranges, the discovered call or data flow, and unresolved ambiguity requiring further inspection.","tools":["Read","Grep","Glob"],"disallowedTools":["Agent","Bash","PowerShell","Workflow","Monitor","CronCreate","RemoteTrigger","ScheduleWakeup","SendMessage","mcp__*"],"model":"haiku","effort":"low","maxTurns":8,"background":false}}'

for cmd in claude jq flock pgrep date awk mktemp; do
    command -v "$cmd" >/dev/null 2>&1 || { printf 'clause-core: missing dependency: %s\n' "$cmd" >&2; exit 127; }
done

is_uint() { [[ "${1:-}" =~ ^[0-9]+$ ]]; }
is_number() { [[ "${1:-}" =~ ^[0-9]+([.][0-9]+)?$ ]]; }
ge() { awk -v a="$1" -v b="$2" 'BEGIN { exit !(a >= b) }'; }

if ! is_uint "$SUPERVISOR_PID" || (( SUPERVISOR_PID <= 1 )) \
    || [[ "$PPID" != "$SUPERVISOR_PID" || -z "$RUN_DIR" || -z "$RUN_ID" \
    || -z "$AUTH_FILE" || -z "$AUTH_TOKEN" || ! -s "$AUTH_FILE" ]] \
    || ! jq -e --argjson pid "$SUPERVISOR_PID" --arg run "$RUN_ID" --arg token "$AUTH_TOKEN" \
        '.supervisor_pid==$pid and .run_id==$run and .token==$token' "$AUTH_FILE" >/dev/null 2>&1; then
    printf 'clause-core: denied; run through ~/.local/bin/clause.\n' >&2
    exit 77
fi

[[ "$AUTO_RESUME" == 0 || "$AUTO_RESUME" == 1 ]] || { printf 'clause-core: CLAUSE_AUTO_RESUME must be 0 or 1.\n' >&2; exit 64; }
[[ "$OPTIMIZATION_PROFILE" == 0 || "$OPTIMIZATION_PROFILE" == 1 ]] || { printf 'clause-core: CLAUSE_OPTIMIZATION_PROFILE must be 0 or 1.\n' >&2; exit 64; }

INSTANCE_FILE="$RUN_DIR/instance.json"
TELEMETRY_FILE="$RUN_DIR/telemetry.json"
SESSION_FILE="$RUN_DIR/session.json"
HOOK_MARKER_FILE="$RUN_DIR/hook-marker.json"
active_pid=''
generation=0
watch_pid=''

log() { printf '%s core_pid=%s run_id=%s %s\n' "$(date --iso-8601=seconds)" "$$" "$RUN_ID" "$*" >>"$LOG_FILE"; }
children_of() { pgrep -P "$1" 2>/dev/null || true; }
signal_tree() { local sig="$1" pid="$2" child; while read -r child; do [[ -n "$child" ]] && signal_tree "$sig" "$child"; done < <(children_of "$pid"); kill "-$sig" "$pid" 2>/dev/null || true; }

publish_phase() {
    local phase="$1" pid="${2:-0}" kind="${3:-}" tmp
    tmp="$(mktemp "$RUN_DIR/.instance.XXXXXX")" || return 1
    jq -n --arg phase "$phase" --argjson active_pid "$pid" --arg active_kind "$kind" \
        --argjson generation "$generation" --argjson phase_started_at "$(date +%s)" \
        '{phase:$phase,active_pid:$active_pid,active_kind:$active_kind,generation:$generation,phase_started_at:$phase_started_at}' >"$tmp" || return 1
    chmod 600 "$tmp"; mv -f "$tmp" "$INSTANCE_FILE"
}

stop_active() {
    [[ -n "$active_pid" ]] || return 0
    publish_phase stopping "$active_pid" "${1:-process}" || true
    if kill -0 "$active_pid" 2>/dev/null; then
        kill -INT "$active_pid" 2>/dev/null || true; sleep "$TERM_GRACE_SECONDS"
    fi
    if kill -0 "$active_pid" 2>/dev/null; then
        signal_tree TERM "$active_pid"; sleep "$TERM_GRACE_SECONDS"
    fi
    kill -0 "$active_pid" 2>/dev/null && signal_tree KILL "$active_pid"
    active_pid=''; publish_phase idle 0 '' || true
}

cleanup() {
    local rc=$?
    trap - EXIT INT TERM HUP
    [[ -n "$watch_pid" ]] && kill "$watch_pid" 2>/dev/null || true
    stop_active cleanup
    exit "$rc"
}
trap cleanup EXIT
trap 'exit 130' INT TERM HUP

telemetry_safe() {
    local file="$1" expected_generation="$2" now updated observed five seven
    [[ -s "$file" ]] && jq -e . "$file" >/dev/null 2>&1 || return 1
    now="$(date +%s)"; updated="$(jq -r '.updated_at // 0' "$file")"; observed="$(jq -r '.generation // 0' "$file")"
    is_uint "$updated" && (( updated > 0 && now - updated <= TELEMETRY_STALE_SECONDS )) || return 1
    [[ "$observed" == "$expected_generation" ]] || return 1
    five="$(jq -r '.five_hour.used_percentage // empty' "$file")"; seven="$(jq -r '.seven_day.used_percentage // empty' "$file")"
    is_number "$five" && is_number "$seven" || return 1
    ! ge "$five" "$FIVE_HOUR_STOP" && ! ge "$seven" "$SEVEN_DAY_STOP"
}

hook_ready() {
    [[ -s "$HOOK_MARKER_FILE" ]] && jq -e --arg run "$RUN_ID" --argjson generation "$generation" \
        '.run_id==$run and .generation==$generation' "$HOOK_MARKER_FILE" >/dev/null 2>&1
}

launch_env() {
    CLAUSE_RUN_ID="$RUN_ID" CLAUSE_RUN_DIR="$RUN_DIR" CLAUSE_GENERATION="$generation" \
    CLAUSE_HOOK_MARKER_FILE="$HOOK_MARKER_FILE" CLAUSE_5H_STOP="$FIVE_HOUR_STOP" CLAUSE_7D_STOP="$SEVEN_DAY_STOP" \
    CLAUDE_CODE_DISABLE_BACKGROUND_TASKS=1 CLAUDE_CODE_FORK_SUBAGENT=0 CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=0 \
    CLAUDE_CODE_SUBAGENT_MODEL=haiku CLAUDE_CODE_USE_POWERSHELL_TOOL=0 "$@"
}

probe_until_safe() {
    local delay="$PROBE_RETRY_INITIAL_SECONDS" probe_file started
    while true; do
        generation=$((generation + 1)); rm -f "$HOOK_MARKER_FILE"
        probe_file="$RUN_DIR/probe-$generation.json"; rm -f "$probe_file"
        launch_env env CLAUSE_PROBE_TELEMETRY_FILE="$probe_file" CLAUSE_PROBE_GENERATION="$generation" CLAUSE_ACTIVE_KIND=reset-probe \
            claude --settings "$PROBE_SETTINGS_JSON" --model haiku --effort low --no-session-persistence \
            'Reply with exactly CLAUSE_PROBE and wait.' </dev/tty >/dev/tty 2>/dev/tty &
        active_pid=$!; publish_phase probe "$active_pid" reset-probe || exit 78
        started="$(date +%s)"
        while kill -0 "$active_pid" 2>/dev/null; do
            if hook_ready && telemetry_safe "$probe_file" "$generation"; then
                stop_active reset-probe; rm -f "$probe_file"; log "action=probe_safe generation=$generation"; return 0
            fi
            if (( $(date +%s) - started >= PROBE_TIMEOUT_SECONDS )); then break; fi
            sleep "$POLL_SECONDS"
        done
        stop_active reset-probe; rm -f "$probe_file"
        log "action=probe_retry delay=$delay"
        sleep "$delay"; (( delay < PROBE_RETRY_MAX_SECONDS )) && delay=$((delay * 2)); (( delay > PROBE_RETRY_MAX_SECONDS )) && delay="$PROBE_RETRY_MAX_SECONDS"
    done
}

watch_work() {
    local started="$(date +%s)"
    while kill -0 "$active_pid" 2>/dev/null; do
        if ! hook_ready && (( $(date +%s) - started >= HOOK_GRACE_SECONDS )); then
            log 'action=hook_missing'; stop_active work; return 78
        fi
        if [[ -s "$TELEMETRY_FILE" ]] && jq -e . "$TELEMETRY_FILE" >/dev/null 2>&1; then
            five="$(jq -r '.five_hour.used_percentage // empty' "$TELEMETRY_FILE")"; seven="$(jq -r '.seven_day.used_percentage // empty' "$TELEMETRY_FILE")"
            if is_number "$five" && is_number "$seven" && { ge "$five" "$FIVE_HOUR_STOP" || ge "$seven" "$SEVEN_DAY_STOP"; }; then
                log "action=threshold five=$five seven=$seven"; stop_active work; return 75
            fi
        elif (( $(date +%s) - started >= TELEMETRY_GRACE_SECONDS )); then
            log 'action=telemetry_missing'; stop_active work; return 78
        fi
        sleep "$POLL_SECONDS"
    done
    wait "$active_pid"; return $?
}

publish_phase idle 0 '' || exit 78
probe_until_safe

resume_session=''
resume_model=''
resume_effort=''
while true; do
    generation=$((generation + 1)); rm -f "$HOOK_MARKER_FILE" "$TELEMETRY_FILE"
    launch_args=()
    if [[ -n "$resume_session" ]]; then
        launch_args=(--resume "$resume_session")
        [[ -n "$resume_model" ]] && launch_args+=(--model "$resume_model")
        [[ -n "$resume_effort" ]] && launch_args+=(--effort "$resume_effort")
        launch_args+=("$RESUME_PROMPT")
        settings="$RESUME_SETTINGS_JSON"
    else
        launch_args=("$@")
        settings="$RUNTIME_SETTINGS_JSON"
    fi
    (( OPTIMIZATION_PROFILE == 0 )) && settings="$SAFETY_SETTINGS_JSON"

    launch_env env CLAUSE_ACTIVE_KIND=work claude --settings "$settings" --agents "$EXPLORE_AGENT_JSON" \
        "${launch_args[@]}" </dev/tty >/dev/tty 2>/dev/tty &
    active_pid=$!; publish_phase active "$active_pid" work || exit 78
    watch_work; rc=$?
    active_pid=''; publish_phase idle 0 '' || true

    if (( rc != 75 )); then exit "$rc"; fi
    if [[ "$AUTO_RESUME" != 1 ]]; then exit 75; fi
    [[ -s "$SESSION_FILE" ]] && jq -e . "$SESSION_FILE" >/dev/null 2>&1 || { printf 'clause-core: threshold stop lacked session identity; not resuming.\n' >&2; exit 76; }
    resume_session="$(jq -r '.session_id // empty' "$SESSION_FILE")"
    resume_model="$(jq -r '.model.id // empty' "$SESSION_FILE")"
    resume_effort="$(jq -r '.effort // empty' "$SESSION_FILE")"
    [[ -n "$resume_session" && "$resume_session" != unknown ]] || exit 76
    probe_until_safe
done
