#!/usr/bin/env bash
# Clause: fail-closed supervisor for Claude Code.

set -uo pipefail

STATE_DIR="${CLAUSE_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/clause}"
RUNS_DIR="$STATE_DIR/runs"
LOG_FILE="$STATE_DIR/clause.log"
CORE="$HOME/.local/libexec/clause/clause-core"

FIVE_HOUR_STOP="${CLAUSE_5H_STOP:-90}"
SEVEN_DAY_STOP="${CLAUSE_7D_STOP:-90}"

# Safety timings are intentionally not runtime-configurable.
POLL_SECONDS=1
INSTANCE_GRACE=10
TELEMETRY_STARTUP_GRACE=60
TELEMETRY_STALE_SECONDS=30
USAGE_DATA_GRACE=180
BLOCK_HANDLING_GRACE=15
PROBE_MAX_SECONDS=120
STOPPING_MAX_SECONDS=12
TERM_GRACE=5
HEARTBEAT_STALE_SECONDS=5

is_uint() { [[ "${1:-}" =~ ^[0-9]+$ ]]; }
is_number() { [[ "${1:-}" =~ ^[0-9]+([.][0-9]+)?$ ]]; }
ge() { awk -v a="$1" -v b="$2" 'BEGIN { exit !(a >= b) }'; }

for cmd in jq pgrep date awk mktemp flock od tr id; do
    command -v "$cmd" >/dev/null 2>&1 || {
        printf 'clause: fail-closed dependency missing: %s\n' "$cmd" >&2
        exit 127
    }
done

for pair in "CLAUSE_5H_STOP:$FIVE_HOUR_STOP" "CLAUSE_7D_STOP:$SEVEN_DAY_STOP"; do
    name="${pair%%:*}"
    value="${pair#*:}"
    if ! is_number "$value" || ! awk -v v="$value" 'BEGIN { exit !(v > 0 && v <= 90) }'; then
        printf 'clause: %s must be greater than 0 and no greater than 90.\n' "$name" >&2
        exit 64
    fi
done

# The bypass is explicit and intentional. No environment variable bypass exists.
bypass=0
forward=()
for arg in "$@"; do
    case "$arg" in
        --clause-bypass) bypass=1 ;;
        *) forward+=("$arg") ;;
    esac
done
set -- "${forward[@]}"

if [[ "$bypass" == "1" ]]; then
    command -v claude >/dev/null 2>&1 || {
        printf 'clause: claude executable not found.\n' >&2
        exit 127
    }
    exec claude "$@"
fi

# Clause supports foreground interactive sessions only. Detached, remote,
# print-mode, and safe-mode invocations cannot be supervised by status-line
# telemetry and therefore fail closed rather than silently running unguarded.
expect_restricted_value=''
for arg in "$@"; do
    if [[ -n "$expect_restricted_value" ]]; then
        case "$expect_restricted_value:$arg" in
            permission-mode:bypassPermissions|permission-mode:dontAsk|teammate-mode:*|advisor:*|agent:*|plugin-dir:*|mcp-config:*)
                printf 'clause: unsupported unguardable option: --%s %s (use --clause-bypass intentionally).\n' "$expect_restricted_value" "$arg" >&2
                exit 77
                ;;
        esac
        expect_restricted_value=''
        continue
    fi

    case "$arg" in
        -p|-p*|--print|--print=*|--bg|--background|--cloud|--remote|--remote-control|--remote-control=*|--rc|--safe-mode|--no-session-persistence|--dangerously-skip-permissions|--allow-dangerously-skip-permissions|--settings|--settings=*|--agents|--agents=*|--setting-sources|--setting-sources=*|--plugin-dir=*|--mcp-config=*|--advisor=*|--agent=*|--teammate-mode=*|--permission-mode=bypassPermissions|--permission-mode=dontAsk)
            printf 'clause: unsupported unguardable mode: %s (use --clause-bypass intentionally).\n' "$arg" >&2
            exit 77
            ;;
        --permission-mode)
            expect_restricted_value='permission-mode'
            ;;
        --teammate-mode)
            expect_restricted_value='teammate-mode'
            ;;
        --advisor)
            expect_restricted_value='advisor'
            ;;
        --agent)
            expect_restricted_value='agent'
            ;;
        --plugin-dir)
            expect_restricted_value='plugin-dir'
            ;;
        --mcp-config)
            expect_restricted_value='mcp-config'
            ;;
    esac
done

if [[ -n "$expect_restricted_value" ]]; then
    printf 'clause: missing value for unsupported option --%s.\n' "$expect_restricted_value" >&2
    exit 77
fi

first_non_option=''
for arg in "$@"; do
    if [[ "$arg" != -* ]]; then
        first_non_option="$arg"
        break
    fi
done
case "$first_non_option" in
    agents|attach|auto-mode|daemon|gateway|logs|remote-control|respawn|stop|kill|ultrareview|cloud|teleport)
        printf 'clause: unsupported detached or externally managed command: %s (use --clause-bypass intentionally).\n' "$first_non_option" >&2
        exit 77
        ;;
esac

if [[ ! -x "$CORE" ]]; then
    printf 'clause: fail-closed core not executable: %s\n' "$CORE" >&2
    exit 127
fi

mkdir -p "$RUNS_DIR"
chmod 700 "$STATE_DIR" "$RUNS_DIR" 2>/dev/null || true

# One account-level Clause session at a time. Multiple supervised sessions can
# cross the threshold concurrently before either receives fresh telemetry.
exec 8>"$STATE_DIR/active.lock"
if ! flock -n 8; then
    printf 'clause: another Clause session is already active; refusing concurrent execution.\n' >&2
    exit 81
fi

run_id="$(cat /proc/sys/kernel/random/uuid 2>/dev/null || printf '%s-%s-%s' "$$" "$(date +%s)" "$RANDOM")"
run_dir="$RUNS_DIR/$run_id"
mkdir -m 700 "$run_dir" || exit 127
heartbeat_file="$run_dir/supervisor-heartbeat.json"
auth_file="$run_dir/supervisor-auth.json"
instance_file="$run_dir/instance.json"
telemetry_file="$run_dir/telemetry.json"
auth_token="$(od -An -N32 -tx1 /dev/urandom 2>/dev/null | tr -d ' \n')"
[[ -n "$auth_token" ]] || auth_token="$run_id-$$-$RANDOM"

write_atomic_json() {
    local target="$1" filter="$2" tmp
    shift 2
    tmp="$(mktemp "$run_dir/.json.XXXXXX")" || return 1
    jq -n "$@" "$filter" >"$tmp" || { rm -f "$tmp"; return 1; }
    chmod 600 "$tmp"
    mv -f "$tmp" "$target"
}

write_atomic_json "$auth_file" '{supervisor_pid:$pid,run_id:$run_id,token:$token}' \
    --argjson pid "$$" --arg run_id "$run_id" --arg token "$auth_token" || exit 127

core_pid=''
active_pid=''
active_kind=''
active_generation=0
phase='initializing'
phase_started="$(date +%s)"
telemetry_seen=0
usage_seen=0
block_seen_at=0

log() {
    printf '%s supervisor_pid=%s core_pid=%s run_id=%s %s\n' \
        "$(date --iso-8601=seconds)" "$$" "${core_pid:-none}" "$run_id" "$*" >>"$LOG_FILE"
}

children_of() { pgrep -P "$1" 2>/dev/null || true; }

signal_tree() {
    local sig="$1" pid="$2" child
    while read -r child; do
        [[ -n "$child" ]] && signal_tree "$sig" "$child"
    done < <(children_of "$pid")
    kill "-$sig" "$pid" 2>/dev/null || true
}

kill_active() {
    if [[ -n "$active_pid" ]] && kill -0 "$active_pid" 2>/dev/null; then
        signal_tree TERM "$active_pid"
        sleep "$TERM_GRACE"
        kill -0 "$active_pid" 2>/dev/null && signal_tree KILL "$active_pid"
    fi
}

fail_closed() {
    local reason="$1"
    log "action=fail_closed reason=$(printf '%q' "$reason") active_pid=${active_pid:-none} active_kind=${active_kind:-none}"
    printf '\nclause: FAIL CLOSED: %s\n' "$reason" >/dev/tty 2>/dev/null || \
        printf '\nclause: FAIL CLOSED: %s\n' "$reason" >&2
    kill_active
    if [[ -n "$core_pid" ]] && kill -0 "$core_pid" 2>/dev/null; then
        signal_tree TERM "$core_pid"
        sleep "$TERM_GRACE"
        kill -0 "$core_pid" 2>/dev/null && signal_tree KILL "$core_pid"
    fi
}

cleanup() {
    local rc=$?
    trap - EXIT INT TERM HUP
    if [[ -n "$core_pid" ]] && kill -0 "$core_pid" 2>/dev/null; then
        fail_closed 'supervisor exited while guarded work was active'
    else
        kill_active
    fi
    rm -rf "$run_dir"
    exit "$rc"
}

on_signal() {
    fail_closed 'supervisor received a termination signal'
    core_pid=''
    active_pid=''
    exit 130
}

trap cleanup EXIT
trap on_signal INT TERM HUP

write_heartbeat() {
    write_atomic_json "$heartbeat_file" '{supervisor_pid:$pid,run_id:$run_id,updated_at:$now}' \
        --argjson pid "$$" --arg run_id "$run_id" --argjson now "$(date +%s)"
}

read_instance() {
    local new_phase new_pid new_kind new_generation new_started
    [[ -s "$instance_file" ]] || return 1
    jq -e . "$instance_file" >/dev/null 2>&1 || return 2
    new_phase="$(jq -r '.phase // empty' "$instance_file")"
    new_pid="$(jq -r '.active_pid // 0' "$instance_file")"
    new_kind="$(jq -r '.active_kind // empty' "$instance_file")"
    new_generation="$(jq -r '.generation // 0' "$instance_file")"
    new_started="$(jq -r '.phase_started_at // 0' "$instance_file")"
    [[ -n "$new_phase" ]] || return 2
    is_uint "$new_pid" || return 2
    is_uint "$new_generation" || return 2
    is_uint "$new_started" && (( new_started > 0 )) || return 2

    if [[ "$new_generation" != "$active_generation" || "$new_phase" != "$phase" || "$new_pid" != "${active_pid:-0}" ]]; then
        phase="$new_phase"
        phase_started="$new_started"
        active_generation="$new_generation"
        active_pid=''
        (( new_pid > 1 )) && active_pid="$new_pid"
        active_kind="$new_kind"
        telemetry_seen=0
        usage_seen=0
        block_seen_at=0
        log "action=phase phase=$phase active_kind=${active_kind:-none} active_pid=${active_pid:-none} generation=$active_generation"
    fi
}

telemetry_fresh() {
    local now updated generation
    [[ -s "$telemetry_file" ]] && jq -e . "$telemetry_file" >/dev/null 2>&1 || return 1
    now="$(date +%s)"
    updated="$(jq -r '.updated_at // 0' "$telemetry_file")"
    generation="$(jq -r '.generation // 0' "$telemetry_file")"
    is_uint "$updated" && (( updated > 0 )) || return 1
    [[ "$generation" == "$active_generation" ]] || return 1
    (( now - updated <= TELEMETRY_STALE_SECONDS ))
}

usage_available() {
    local five seven
    five="$(jq -r '.five_hour.used_percentage // empty' "$telemetry_file" 2>/dev/null)"
    seven="$(jq -r '.seven_day.used_percentage // empty' "$telemetry_file" 2>/dev/null)"
    is_number "$five" && is_number "$seven"
}

account_blocked() {
    local five seven
    five="$(jq -r '.five_hour.used_percentage // empty' "$telemetry_file" 2>/dev/null)"
    seven="$(jq -r '.seven_day.used_percentage // empty' "$telemetry_file" 2>/dev/null)"
    is_number "$five" && ge "$five" "$FIVE_HOUR_STOP" && return 0
    is_number "$seven" && ge "$seven" "$SEVEN_DAY_STOP" && return 0
    return 1
}

log "action=supervisor_start core=$(printf '%q' "$CORE") argc=$#"
write_heartbeat || exit 127

CLAUSE_SUPERVISOR_PID="$$" \
CLAUSE_RUN_ID="$run_id" \
CLAUSE_RUN_DIR="$run_dir" \
CLAUSE_AUTH_FILE="$auth_file" \
CLAUSE_AUTH_TOKEN="$auth_token" \
CLAUSE_5H_STOP="$FIVE_HOUR_STOP" \
CLAUSE_7D_STOP="$SEVEN_DAY_STOP" \
"$CORE" "$@" </dev/tty >/dev/tty 2>/dev/tty &
core_pid=$!

instance_deadline=$(( $(date +%s) + INSTANCE_GRACE ))

while kill -0 "$core_pid" 2>/dev/null; do
    now="$(date +%s)"
    write_heartbeat || {
        fail_closed 'could not publish supervisor heartbeat'
        core_pid=''
        exit 78
    }

    read_rc=0
    read_instance || read_rc=$?
    if (( read_rc == 2 )); then
        fail_closed 'core published a malformed active-instance record'
        core_pid=''
        exit 78
    elif (( read_rc == 1 && now >= instance_deadline )); then
        fail_closed 'core did not publish an active-instance record'
        core_pid=''
        exit 78
    fi

    if [[ -n "$active_pid" ]] && kill -0 "$active_pid" 2>/dev/null; then
        if [[ "$phase" == "active" ]]; then
            if telemetry_fresh; then
                telemetry_seen=1
            elif (( telemetry_seen == 1 || now - phase_started >= TELEMETRY_STARTUP_GRACE )); then
                fail_closed 'guarded-session telemetry is missing or stale'
                core_pid=''
                exit 78
            fi

            if (( telemetry_seen == 1 )) && usage_available; then
                usage_seen=1
            elif (( now - phase_started >= USAGE_DATA_GRACE )); then
                fail_closed 'both rate-limit percentages never became available'
                core_pid=''
                exit 78
            fi

            if (( usage_seen == 1 )) && account_blocked; then
                if (( block_seen_at == 0 )); then
                    block_seen_at="$now"
                    log "action=block_observed active_pid=$active_pid"
                elif (( now - block_seen_at >= BLOCK_HANDLING_GRACE )); then
                    fail_closed "threshold crossed but core did not stop Claude within ${BLOCK_HANDLING_GRACE}s"
                    core_pid=''
                    exit 79
                fi
            else
                block_seen_at=0
            fi
        elif [[ "$phase" == "probe" ]]; then
            if (( now - phase_started > PROBE_MAX_SECONDS )); then
                fail_closed 'reset telemetry probe exceeded its hard runtime limit'
                core_pid=''
                exit 78
            fi
        elif [[ "$phase" == "stopping" ]]; then
            if (( now - phase_started > STOPPING_MAX_SECONDS )); then
                fail_closed 'core could not terminate the advertised process promptly'
                core_pid=''
                exit 79
            fi
        else
            fail_closed "active process published in invalid phase: $phase"
            core_pid=''
            exit 78
        fi
    elif [[ "$phase" == "active" || "$phase" == "probe" ]]; then
        if (( now - phase_started > 5 )); then
            fail_closed "core advertised a dead $phase process without a stopping transition"
            core_pid=''
            exit 78
        fi
    elif [[ "$phase" == "stopping" ]]; then
        if (( now - phase_started > STOPPING_MAX_SECONDS )); then
            fail_closed 'core did not complete its stopping transition'
            core_pid=''
            exit 79
        fi
    fi

    sleep "$POLL_SECONDS"
done

wait "$core_pid"
core_rc=$?
read_instance >/dev/null 2>&1 || true

if [[ -n "$active_pid" ]] && kill -0 "$active_pid" 2>/dev/null; then
    fail_closed "core exited while $active_kind remained running"
    core_pid=''
    active_pid=''
    exit 80
fi

core_pid=''
active_pid=''
exit "$core_rc"
